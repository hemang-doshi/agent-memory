{
  "name": "agent-memory-preflight",
  "version": "2.0.0",
  "description": "Local-first project memory system for coding agents — stores decisions, constraints, command policies, failed attempts, fixes, and lessons in a local SQLite store with deterministic retrieval, keyword/vector/hybrid search, optional reranking, MCP, agent adapters, import/export, backup/restore, and a live-agent proof harness.",
  "type": "module",
  "bin": {
    "agentmem": "./dist/cli/main.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node --import tsx ./src/cli/main.ts"
  },
  "keywords": [
    "cli",
    "memory",
    "mcp",
    "sqlite",
    "agents",
    "local-first",
    "deterministic",
    "protocol",
    "preflight",
    "retrieval",
    "vector-search",
    "candidates",
    "provenance"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hemang-doshi/agent-memory.git"
  },
  "bugs": {
    "url": "https://github.com/hemang-doshi/agent-memory/issues"
  },
  "homepage": "https://github.com/hemang-doshi/agent-memory#readme",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.3.0",
  "devDependencies": {
    "@claude-flow/codex": "3.0.0-alpha.12",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
